#!/bin/sh

clock=$(date '+%H')

case "$clock" in
	"00") icon="¯Äü" ;;
	"01") icon="¯Äé" ;;
	"02") icon="¯Äâ" ;;
	"03") icon="¯Ää" ;;
	"04") icon="¯Äà" ;;
	"05") icon="¯Äå" ;;
	"06") icon="¯Äç" ;;
	"07") icon="¯Äê" ;;
	"08") icon="¯Äë" ;;
	"09") icon="¯Äè" ;;
	"10") icon="¯Äï" ;;
	"11") icon="¯Äî" ;;
	"12") icon="¯Äü" ;;
	"13") icon="¯Äé" ;;
	"14") icon="¯Äâ" ;;
	"15") icon="¯Ää" ;;
	"16") icon="¯Äà" ;;
	"17") icon="¯Äå" ;;
	"18") icon="¯Äç" ;;
	"19") icon="¯Äê" ;;
	"20") icon="¯Äë" ;;
	"21") icon="¯Äè" ;;
	"22") icon="¯Äï" ;;
	"23") icon="¯Äî" ;;
esac

date "+  ´ü│ %Y %b %d (%a)  $icon %H:%M "
